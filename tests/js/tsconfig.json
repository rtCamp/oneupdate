{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": true,
		"baseUrl": "../../",
		"types": [ "jest", "node", "@testing-library/jest-dom" ]
	},
	"include": [
		"./**/*.ts",
		"./**/*.tsx",
		"../../assets/src/**/*.ts",
		"../../assets/src/**/*.tsx"
	],
	"exclude": [
		"../../node_modules",
		"../../build",
		"../../vendor",
		"../../vendor-prefixed"
	]
}
