{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"rootDir": ".",
		"outDir": "./build",
		"paths": {
			"@/*": [ "./assets/src/*" ]
		},
		"types": [ "jest", "node" ],
		"checkJs": false
	},
	"include": [
		"**/*.d.ts",
		"**/*.cjs",
		"**/*.mjs",
		"**/*.ts",
		"**/*.tsx",
		"**/*.json",
		"assets/src/components/PluginCard.js",
		"assets/src/components/PluginGrid.js",
		"assets/src/components/PluginsSharing.js",
		"assets/src/components/S3ZipUploader.js"
	],
	"exclude": [
		"**/build/*",
		"vendor/*",
		"vendor-prefixed/*",
		"node_modules/*",
		"eslint.config.mjs"
	]
}
